__pycache__/
.pytest_cache/
*.py[cod]
*.egg-info/

# Local environments and editor files
.venv/
.env
.DS_Store

# Large or generated project data
data/cache/*
!data/cache/.gitkeep
data/raw_complexes/*
!data/raw_complexes/.gitkeep
data/processed/*/complexes/*
!data/processed/*/complexes/.gitkeep
data/processed/*/manifest.parquet
data/processed/*/schema.json
data/splits/*/*.txt
data/splits/*/split_report.csv
data/benchmarks/*/v*/samples/*.pkl
data/benchmarks/*/v*/ligands/*.sdf
reports/phase0/*.csv
reports/phase0/*.json
runs/phase0_visual_check/
runs/phase2_visual_qc/
runs/phase2_visual_qc_trial/
runs/phase2_5_model_induced_audit/
runs/phase4_0_backend_feasibility/

# External frozen baselines and checkpoints
external/*
!external/AGENTS.md
!external/README.md

# Temporary local work
tmp/**
!tmp/.gitkeep
!tmp/**/
!tmp/**/*.md
